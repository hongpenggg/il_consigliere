# Copy this file to .env and fill in your values
# Get these from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Get this from: https://openrouter.ai/keys
# NOTE: No VITE_ prefix — this is server-side only (used by /api/generate.ts)
OPENROUTER_API_KEY=your-openrouter-key-here

# Your deployed Vercel URL — used for CORS in /api/generate.ts
# Leave blank locally, set it after first deploy
ALLOWED_ORIGIN=https://your-app.vercel.app
