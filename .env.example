# Copy this file to .env and fill in your values
# Get these from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Get this from: https://openrouter.ai/keys
# NOTE: No VITE_ prefix — this is server-side only (used by /api/generate.ts)
OPENROUTER_API_KEY=your-openrouter-key-here

# Server-side Supabase credentials (required by /api/generate.ts auth + audit logs)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Upstash Redis for /api/generate.ts rate limiting
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Your deployed Vercel URL — used for CORS in /api/generate.ts
# Leave blank locally, set it after first deploy
ALLOWED_ORIGIN=https://your-app.vercel.app
